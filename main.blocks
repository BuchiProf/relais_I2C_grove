<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="ybd)p/AyVN@|rk%-~:36" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="uX.{uewSVm%cdu16#?5A"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace seeedRelay {" line1="" line2="    // Cette partie crée un menu déroulant pour ON et OFF" line3="    export enum RelayState {" line4="        // % block=&quot;allumé&quot;" line5="        On = 1," line6="        // % block=&quot;éteint&quot;" line7="        Off = 0" line8="    }" line9="" line10="    /**" line11="     * Change l'état d'un relais spécifique (1 à 4)" line12="     */" line13="    // % block=&quot;mettre le relais %num à %state&quot;" line14="    // % num.min=1 num.max=4 num.defl=1" line15="    export function controlRelay(num: number, state: RelayState): void {" line16="        let buf = pins.createBuffer(2);" line17="        buf[0] = num;" line18="        buf[1] = state;" line19="        pins.i2cWriteBuffer(0x11, buf);" line20="    }" line21="" line22="    /**" line23="     * Éteint tous les relais" line24="     */" line25="    // % block=&quot;éteindre tous les relais&quot;" line26="    export function allOff(): void {" line27="        for (let i = 1; i &lt;= 4; i++) {" line28="            controlRelay(i, RelayState.Off);" line29="        }" line30="    }" line31="}" numlines="32"></mutation></block></statement></block></xml>